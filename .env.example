# Pu_Sok - Telegram Security Bot Configuration
# Copy this file to .env and fill in your values

# Your Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_bot_token_here_from_botfather

# Specific Admin ID who receives violation reports
# Get your ID using @userinfobot or running: python -c "from telebot import util; print(util.extract_arguments('/start'))"
SPECIFIC_ADMIN_ID=123456789

# Optional: Render.com PORT (automatically set by Render)
PORT=10000
